# Optional but recommended. Authenticated GitHub requests have much higher rate limits.
GITHUB_TOKEN=

# Optional. If OPENAI_API_KEY and OPENAI_MODEL are both set, RepoPulse will try AI analysis.
# If either is missing or the request fails, it falls back to local heuristic analysis.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional runtime tuning.
REPOPULSE_TIMEZONE=Asia/Shanghai
REPOPULSE_STORE_PATH=data/repopulse.store.json
